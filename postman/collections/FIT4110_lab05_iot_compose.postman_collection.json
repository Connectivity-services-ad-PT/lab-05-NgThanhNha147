{
  "info": {
    "name": "FIT4110 Lab05 IoT Compose",
    "description": "End-to-end checks for the Lab 05 Docker Compose stack.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "00_Readiness",
      "item": [
        {
          "name": "GET /health - API is ready with DB and AI",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('API health returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('DB and AI dependencies are ready', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql('ok');",
                  "  pm.expect(body.dependencies.database).to.eql('ok');",
                  "  pm.expect(body.dependencies.ai).to.eql('ok');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "GET /health - AI service is ready",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{aiUrl}}/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('AI health returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('AI service reports ok', function () {",
                  "  pm.expect(pm.response.json().status).to.eql('ok');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST /predict - AI service returns a dummy prediction",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{aiUrl}}/predict"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('AI predict returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('AI predict returns objects and confidence', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.objects).to.be.an('array').that.is.not.empty;",
                  "  pm.expect(body.confidence).to.be.an('array').that.is.not.empty;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "01_Readings",
      "item": [
        {
          "name": "POST /readings - creates a temperature reading",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"device_id\": \"ESP32-LAB-A01\",\n  \"metric\": \"temperature\",\n  \"value\": 31.5,\n  \"unit\": \"celsius\",\n  \"timestamp\": \"2026-06-09T08:30:00+07:00\"\n}"
            },
            "url": "{{baseUrl}}/readings"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Reading is created', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Response contains reading id', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.accepted).to.eql(true);",
                  "  pm.expect(body.reading_id).to.match(/^R-[0-9]{8}-[0-9]{4}$/);",
                  "  pm.environment.set('readingId', body.reading_id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "GET /readings/latest - returns stored readings",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": "{{baseUrl}}/readings/latest?device_id=ESP32-LAB-A01&limit=5"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Latest readings returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Latest readings include items', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.items).to.be.an('array').that.is.not.empty;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "GET /readings/{reading_id} - returns created reading",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": "{{baseUrl}}/readings/{{readingId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Reading detail returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Reading detail matches created id', function () {",
                  "  pm.expect(pm.response.json().reading_id).to.eql(pm.environment.get('readingId'));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02_Negative",
      "item": [
        {
          "name": "POST /readings - missing token is rejected",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"device_id\": \"ESP32-LAB-A01\",\n  \"metric\": \"temperature\",\n  \"value\": 31.5,\n  \"unit\": \"celsius\",\n  \"timestamp\": \"2026-06-09T08:30:00+07:00\"\n}"
            },
            "url": "{{baseUrl}}/readings"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Missing token returns 401', function () {",
                  "  pm.response.to.have.status(401);",
                  "});",
                  "pm.test('Problem details are returned', function () {",
                  "  pm.expect(pm.response.json().title).to.eql('Unauthorized');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST /readings - value above max is rejected",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"device_id\": \"ESP32-LAB-A01\",\n  \"metric\": \"temperature\",\n  \"value\": 81,\n  \"unit\": \"celsius\",\n  \"timestamp\": \"2026-06-09T08:30:00+07:00\"\n}"
            },
            "url": "{{baseUrl}}/readings"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Invalid reading returns 422', function () {",
                  "  pm.response.to.have.status(422);",
                  "});",
                  "pm.test('Validation problem details are returned', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.title).to.eql('Validation error');",
                  "  pm.expect(body.status).to.eql(422);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    }
  ]
}
